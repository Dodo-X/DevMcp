# ============================================
# Docker 构建忽略规则 - v6.0
# ============================================
#
# 目标: 减小镜像体积 + 灵活部署模式
#
# 部署模式:
#   轻量模式 (推荐): 不包含模型 (~150MB)
#     docker build --build-arg SKIP_MODEL=true -t devpartner:lite .
#     docker run -v ./models:/app/models devpartner:lite
#
#   完整模式: 包含模型 (~6.5GB)
#     取消下面的 models/*.gguf 注释
#     docker build -t devpartner:full .
#

# Git 仓库（容器内不需要，且会导致误判 git 可用）
.git/
.gitignore
.gitattributes

# GitHub
.github/

# 本地 IDE 用户配置
.idea/
.vscode/
*.iml

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg

# 本地数据目录（通过 volume 挂载，不打包进镜像）
data/

# 系统文件
.DS_Store
Thumbs.db
*.swp
*.swo

# CodeBuddy 本地数据
.codebuddy/

# 文档（减小镜像体积）
README.md
*.md

# Docker 自身
Dockerfile
docker-compose.yml
.dockerignore

# 测试
tests/
*_test.py
_test_*.py

# 临时文件
*.tmp
*.bak
*.log

# ⭐ 模型文件（v6.0: 默认不打包进镜像）
#
# 部署方式选择:
#   方式A (推荐): 轻量镜像 + volume 挂载模型
#     docker build --build-arg SKIP_MODEL=true -t devpartner:lite .
#     docker run -v ./models:/app/models devpartner:lite
#
#   方式B: 完整镜像（包含模型，~6.5GB）
#     取消下面的注释即可打包模型
#     注意: 构建时间较长，镜像体积大
#
models/*.gguf           # 默认排除（使用轻量模式）
models/*.bin            # 默认排除
!models/README.md       # 保留说明文档
!models/.gitkeep        # 保留占位符